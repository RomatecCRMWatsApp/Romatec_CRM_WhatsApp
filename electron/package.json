{
  "name": "romatec-crm",
  "version": "1.1.1",
  "description": "Romatec CRM - Gestão de Relacionamento com o Cliente",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:icon": "node make-icon.mjs",
    "build:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.romatec.crm",
    "productName": "Romatec CRM",
    "copyright": "Copyright © 2026 Romatec Consultoria Imobiliária",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "offline.html"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Romatec CRM",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
