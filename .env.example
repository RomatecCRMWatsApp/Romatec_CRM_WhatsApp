# ─── Banco de Dados ────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/romatec_crm

# ─── Autenticação ──────────────────────────────────────────────────────────
JWT_SECRET=sua_chave_secreta_aqui

# ─── Z-API (WhatsApp) ──────────────────────────────────────────────────────
# Obtido em app.z-api.io → sua instância
ZAPI_INSTANCE_ID=SUA_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN   # opcional (segurança extra)

# ─── Fan-out de webhook pra ZAYRA (RomatecVoiceAgent) ──────────────────────
# Quando configurado, mensagens do CEO no WhatsApp são repassadas pra ZAYRA
# (e o bot do CRM NÃO responde no caso do CEO, pra evitar dupla resposta).
# Outros leads continuam respondidos normalmente pelo bot do CRM.
# Filtro: só dispara quando from.phone == CEO_WHATSAPP_PHONE.
CEO_WHATSAPP_PHONE=             # ex: 5599991811246
ZAYRA_WEBHOOK_URL=              # ex: https://romatecvoiceagent-production.up.railway.app/webhook/whatsapp

# ─── Telegram (Notificações) ───────────────────────────────────────────────
# Pode ser configurado também pela tela de Configurações no sistema
TELEGRAM_BOT_TOKEN=110201543:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
TELEGRAM_CHAT_ID=-1001234567890

# ─── OpenAI (Bot IA) ───────────────────────────────────────────────────────
# Pode ser configurado também pela tela de Configurações no sistema
OPENAI_API_KEY=sk-...

# ─── Cloudinary (Upload de imagens) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ─── Servidor ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
